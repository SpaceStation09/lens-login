# Lens environment: mainnet or testnet.
NEXT_PUBLIC_LENS_ENV=testnet

# Optional override. Must be a Lens App address valid for the selected environment.
NEXT_PUBLIC_LENS_APP_ADDRESS=your-lens-app-address

# Must match the URL where the demo is running.
NEXT_PUBLIC_APP_ORIGIN=http://localhost:3000

# Demo session signing secret.
SESSION_SECRET=replace-me
